{
  "instance_name": "longterm",
  "jobs": [
    {
      "name": "main",
      "sources": [{"type": "postgres", "host": "database", "database": "app",
        "user": "app", "password": "${DB_PASSWORD}"}],
      "destinations": [{"type": "local"}, {"type": "s3", "bucket": "archive",
        "access_key": "${S3_KEY}", "secret_key": "${S3_SECRET}", "prefix": "app/"}],
      "schedule": {"mode": "cron", "cron": "0 2 * * *"},
      "retention": {"count": 7, "age_days": 0,
                    "gfs": {"daily": 7, "weekly": 4, "monthly": 12}, "smart_last": true}
    }
  ]
}
