{
  "instance_name": "shop",
  "jobs": [
    {
      "name": "db",
      "sources": [
        {"type": "mysql", "host": "database", "port": 3306, "databases": ["shop", "sessions"],
         "user": "root", "password": "${MYSQL_ROOT_PASSWORD}"}
      ],
      "destinations": [{"type": "local"}, {"type": "s3", "bucket": "shop-backups",
        "access_key": "${S3_ACCESS_KEY}", "secret_key": "${S3_SECRET_KEY}", "prefix": "shop/"}],
      "schedule": {"mode": "interval", "interval_hours": 6},
      "retention": {"count": 28}
    }
  ]
}
